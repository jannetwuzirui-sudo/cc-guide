---
const base = import.meta.env.BASE_URL;

interface SidebarSection {
  title: string;
  items: { label: string; href: string }[];
}

const sections: SidebarSection[] = [
  {
    title: '基础教程',
    items: [
      { label: '5分钟快速上手', href: `${base}basics/quick-start` },
      { label: '三种模式', href: `${base}basics/three-modes` },
      { label: '核心命令精选', href: `${base}basics/slash-commands` },
      { label: '快捷键速查', href: `${base}basics/shortcuts` },
    ],
  },
  {
    title: '实战案例',
    items: [
      { label: '静态企业站', href: `${base}practice/static-site` },
      { label: '营销落地页', href: `${base}practice/landing-page` },
      { label: '博客站', href: `${base}practice/blog-site` },
      { label: '小型Web应用', href: `${base}practice/mini-app` },
    ],
  },
  {
    title: '部署上线',
    items: [
      { label: '域名购买与解析', href: `${base}deploy/domain-guide` },
      { label: 'GitHub Pages', href: `${base}deploy/github-pages` },
      { label: 'Vercel 部署', href: `${base}deploy/vercel-deploy` },
      { label: '服务器部署', href: `${base}deploy/server-deploy` },
      { label: 'HTTPS/SSL', href: `${base}deploy/https-ssl` },
    ],
  },
  {
    title: '淘宝接单',
    items: [
      { label: '开店与接单入门', href: `${base}taobao/getting-started` },
      { label: '定价策略', href: `${base}taobao/pricing` },
      { label: '客户沟通技巧', href: `${base}taobao/client-communication` },
      { label: '交付流程', href: `${base}taobao/delivery-flow` },
      { label: '售后维护', href: `${base}taobao/after-sales` },
    ],
  },
];

const currentPath = Astro.url.pathname;
---

<aside id="sidebar" class="fixed left-0 top-16 bottom-0 w-64 overflow-y-auto border-r transition-transform
  dark:bg-[var(--color-bg-dark-secondary)] dark:border-[var(--color-border-dark)]
  bg-white border-[var(--color-border-light)]
  -translate-x-full lg:translate-x-0 z-40">
  <nav class="p-4 space-y-6">
    {sections.map(section => (
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider mb-2 opacity-60">{section.title}</h3>
        <ul class="space-y-1">
          {section.items.map(item => (
            <li>
              <a href={item.href}
                class:list={[
                  'block px-3 py-1.5 rounded text-sm transition-colors',
                  currentPath === item.href
                    ? 'bg-[var(--color-primary)] text-white'
                    : 'hover:bg-gray-100 dark:hover:bg-gray-800'
                ]}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
    <div>
      <a href={`${base}faq`} class:list={[
        'block px-3 py-1.5 rounded text-sm transition-colors',
        currentPath === `${base}faq`
          ? 'bg-[var(--color-primary)] text-white'
          : 'hover:bg-gray-100 dark:hover:bg-gray-800'
      ]}>常见问题 FAQ</a>
    </div>
  </nav>
</aside>
